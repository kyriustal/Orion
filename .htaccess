# Orion 2 - Hostinger Apache Configuration
# Forca o uso do server-dist.js para todas as requisicoes

<IfModule mod_passenger.c>
    PassengerAppEnv production
    PassengerAppType node
    PassengerStartupFile server-dist.js
</IfModule>

RewriteEngine On
RewriteRule ^server-dist\.js$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule (.*) server-dist.js [L]
